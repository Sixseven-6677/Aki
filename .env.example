# ─── Facebook Authentication (REQUIRED) ─────────────────────────────────────
# RECOMMENDED: watch a single AppState file on disk. Drop fresh cookies into
# this file at any time (no redeploy needed) and the bot will pick them up
# automatically, re-authenticate, and reset the reconnect circuit breaker.
# The file is encrypted at rest with SESSION_SECRET (AES-256-GCM) after the
# first read, so it is safe to keep on a persistent volume.
FB_APPSTATE_WATCH_FILE=/app/data/appstate-watch.json

# Export your Facebook AppState (cookies) using a browser extension like
# "Cookie Editor" then base64-encode the JSON array.
# Example: echo '[{"key":"c_user","value":"..."}]' | base64
# NOTE: only used when FB_APPSTATE_WATCH_FILE is not set.
# FB_APPSTATE=

# Optional: load AppState from a JSON file path instead of env var (static,
# not watched for changes). Only used when FB_APPSTATE_WATCH_FILE is not set.
# FB_APPSTATE_FILE=/app/data/appstate.json

# ─── Bot Configuration ────────────────────────────────────────────────────────
BOT_PREFIX=/
BOT_ADMIN_IDS=YOUR_FB_USER_ID_HERE

# ─── Session / Security ───────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-secret
FB_SESSION_FILE=data/sessions.json
FB_SESSION_TTL_DAYS=30

# ─── Database (optional — bot works without MongoDB) ─────────────────────────
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/sixsu

# ─── Cache (optional — falls back to in-memory) ───────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=true

# ─── Runtime ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
